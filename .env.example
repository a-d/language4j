# Language Learning Platform - Environment Configuration
# ======================================================
# Copy this file to .env and fill in your values

# ===========================================
# Language Settings
# ===========================================
# Your native language (ISO 639-1 code)
NATIVE_LANGUAGE=de

# The language you want to learn (ISO 639-1 code)
TARGET_LANGUAGE=fr

# ===========================================
# AI Provider Configuration
# ===========================================
# LLM Provider: openai, anthropic, ollama
LLM_PROVIDER=openai

# API Key for your LLM provider
LLM_API_KEY=your-api-key-here

# Model to use (provider-specific)
# OpenAI: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
# Anthropic: claude-3-opus, claude-3-sonnet
# Ollama: llama2, mistral, etc.
LLM_MODEL=gpt-4-turbo-preview

# Optional: Custom base URL for API (useful for Ollama or proxies)
# LLM_BASE_URL=http://localhost:11434

# Spring AI provider flags (enable only the provider you're using)
# Set to 'true' for your chosen provider, 'false' for others
# For OpenAI provider:
#   OPENAI_CHAT_ENABLED=true
#   OLLAMA_CHAT_ENABLED=false
#   ANTHROPIC_CHAT_ENABLED=false
# For Ollama provider:
#   OPENAI_CHAT_ENABLED=false
#   OLLAMA_CHAT_ENABLED=true
#   ANTHROPIC_CHAT_ENABLED=false
OPENAI_CHAT_ENABLED=true
OPENAI_IMAGE_ENABLED=true
OPENAI_SPEECH_ENABLED=true
OPENAI_TRANSCRIPTION_ENABLED=true
OLLAMA_CHAT_ENABLED=false
ANTHROPIC_CHAT_ENABLED=false

# ===========================================
# Speech Services (Optional)
# ===========================================
# Speech-to-Text provider: openai, openai-compatible
STT_PROVIDER=openai

# Speech-to-Text API Key (defaults to LLM_API_KEY if not set)
# STT_API_KEY=

# Custom STT base URL (for local Whisper or compatible services)
# STT_BASE_URL=http://localhost:9000

# STT model
STT_MODEL=whisper-1

# ===========================================
# Text-to-Speech (Optional)
# ===========================================
# Text-to-Speech provider: openai, openai-compatible
TTS_PROVIDER=openai

# Text-to-Speech API Key (defaults to LLM_API_KEY if not set)
# TTS_API_KEY=

# Custom TTS base URL (for local Piper or compatible services)
# TTS_BASE_URL=http://localhost:9001

# TTS model
TTS_MODEL=tts-1

# TTS Voice (OpenAI: alloy, echo, fable, onyx, nova, shimmer)
TTS_VOICE=alloy

# TTS Speed (0.25 to 4.0)
TTS_SPEED=1.0

# ===========================================
# Image Generation (Optional)
# ===========================================
# Image provider: openai, openai-compatible
IMAGE_PROVIDER=openai

# Image API Key (defaults to LLM_API_KEY if not set)
# IMAGE_API_KEY=

# Custom Image base URL (for local Stable Diffusion or compatible services)
# IMAGE_BASE_URL=http://localhost:7860

# Image model (OpenAI: dall-e-3, dall-e-2)
IMAGE_MODEL=dall-e-3

# Image size (256x256, 512x512, 1024x1024, 1792x1024, 1024x1792)
IMAGE_SIZE=1024x1024

# Image quality (standard, hd)
IMAGE_QUALITY=standard

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=jdbc:postgresql://localhost:5433/language_learning
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ===========================================
# Application Settings
# ===========================================
# Server port
SERVER_PORT=8080

# Spring profile (dev, prod)
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# Storage Paths
# ===========================================
CONTENT_PATH=./content
MEDIA_PATH=./media