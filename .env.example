# Language Learning Platform - Environment Configuration
# ======================================================
#
# QUICK START:
# 1. Copy this file to .env: cp .env.example .env
# 2. Choose your provider and configure settings below
# 3. Start the application: cd backend && mvn -pl api-module spring-boot:run
#
# For provider-specific templates, see:
#   .env.ollama    - Ollama (local)
#   .env.lmstudio  - LM Studio (local)

# ===========================================
# Language Settings
# ===========================================
# Your native language (ISO 639-1 code)
NATIVE_LANGUAGE=de

# The language you want to learn
TARGET_LANGUAGE=fr

# ===========================================
# LLM Provider Configuration
# ===========================================
# Choose ONE provider: ollama or openai
#
# OLLAMA (recommended for local deployment):
#   - Set LLM_PROVIDER=ollama
#   - Set OLLAMA_CHAT_ENABLED=true
#   - Set OPENAI_CHAT_ENABLED=false
#
# OPENAI / OpenAI-Compatible (LM Studio, vLLM, etc.):
#   - Set LLM_PROVIDER=openai  
#   - Set OLLAMA_CHAT_ENABLED=false
#   - Set OPENAI_CHAT_ENABLED=true

LLM_PROVIDER=ollama

# Provider feature flags (enable only ONE chat provider)
OLLAMA_CHAT_ENABLED=true
OPENAI_CHAT_ENABLED=false

# ===========================================
# Ollama Configuration
# ===========================================
OLLAMA_BASE_URL=http://localhost:11434

# ===========================================
# OpenAI-Compatible Configuration
# ===========================================
# Used when OPENAI_CHAT_ENABLED=true
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=your-api-key-here

# ===========================================
# LLM Model Settings
# ===========================================
# Model name format depends on provider:
#   Ollama: model:tag (e.g., qwen2.5:7b-instruct-q5_K_M)
#   OpenAI: model-name (e.g., gpt-4-turbo)
LLM_MODEL=qwen2.5:7b-instruct-q5_K_M
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60s

# ===========================================
# Speech Services (Optional)
# ===========================================
# Speech-to-Text (Whisper)
STT_BASE_URL=http://localhost:9000

# Text-to-Speech (Piper)
TTS_BASE_URL=http://localhost:9001
TTS_VOICE=alloy

# ===========================================
# Image Generation (Optional)
# ===========================================
IMAGE_BASE_URL=http://localhost:7860
IMAGE_SIZE=512x512

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=jdbc:postgresql://localhost:5432/language_learning
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ===========================================
# Application Settings
# ===========================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Logging (TRACE, DEBUG, INFO, WARN, ERROR)
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO