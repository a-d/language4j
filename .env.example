# Language Learning Platform - Environment Configuration
# ======================================================
#
# QUICK START:
# 1. Copy one of the provider-specific files to .env:
#    - For Ollama:    cp .env.ollama .env
#    - For LM Studio: cp .env.lmstudio .env
#
# 2. Adjust the settings as needed for your setup
#
# 3. Start the application:
#    cd backend && mvn -pl api-module spring-boot:run
#
# PROVIDER OPTIONS:
# - .env.ollama    : Ollama (Docker/local) - recommended for beginners
# - .env.lmstudio  : LM Studio (OpenAI-compatible) - more model options
#
# This file documents ALL available configuration options.

# ===========================================
# Language Settings
# ===========================================
# Your native language (ISO 639-1 code)
# Examples: en, de, fr, es, it, pt, zh, ja, ko, ru
NATIVE_LANGUAGE=de

# The language you want to learn (ISO 639-1 code)
TARGET_LANGUAGE=fr

# ===========================================
# LLM PROVIDER SELECTION
# ===========================================
# Supported providers: ollama, openai (for OpenAI-compatible APIs)
#
# IMPORTANT: Enable ONLY ONE chat provider at a time!
# The system uses Spring AI which supports multiple providers,
# but only one should be active to avoid conflicts.

# LLM_PROVIDER controls which API format to use
# - ollama: Ollama native API
# - openai: OpenAI-compatible API (works with LM Studio, LocalAI, vLLM, etc.)
LLM_PROVIDER=ollama

# ===========================================
# Provider Feature Flags (Spring AI)
# ===========================================
# These flags control which Spring AI auto-configurations are active.
# Set to 'true' to enable, 'false' to disable.
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │ PROVIDER       │ WHEN TO USE                                       │
# ├─────────────────────────────────────────────────────────────────────┤
# │ OLLAMA         │ Running Ollama locally or in Docker               │
# │ OPENAI         │ OpenAI API, LM Studio, LocalAI, vLLM, etc.       │
# │ ANTHROPIC      │ Claude API (Anthropic)                            │
# └─────────────────────────────────────────────────────────────────────┘

# Ollama Chat (native Ollama API)
# Enable when using Ollama for LLM
OLLAMA_CHAT_ENABLED=true

# OpenAI Chat (OpenAI-compatible API)
# Enable when using: OpenAI, LM Studio, LocalAI, vLLM, etc.
OPENAI_CHAT_ENABLED=false

# Anthropic Chat (Claude API)
# Enable when using Anthropic's Claude
ANTHROPIC_CHAT_ENABLED=false

# OpenAI-compatible auxiliary services
# These work with local services that implement OpenAI's API
OPENAI_IMAGE_ENABLED=false
OPENAI_SPEECH_ENABLED=false
OPENAI_TRANSCRIPTION_ENABLED=false

# ===========================================
# Ollama Configuration
# ===========================================
# Used when OLLAMA_CHAT_ENABLED=true
#
# URL patterns:
# - Local Ollama:  http://localhost:11434
# - Docker Compose: http://ollama:11434 (service name)
# - WSL from Windows: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# ===========================================
# OpenAI-Compatible Configuration
# ===========================================
# Used when OPENAI_CHAT_ENABLED=true
#
# Works with: OpenAI, LM Studio, LocalAI, vLLM, text-generation-webui, etc.
#
# URL patterns:
# - OpenAI API: https://api.openai.com
# - LM Studio (local): http://localhost:1234
# - LM Studio (remote): http://192.168.x.x:1234
# - LocalAI: http://localhost:8080
OPENAI_BASE_URL=https://api.openai.com

# API Key
# - OpenAI: Your actual API key (sk-...)
# - LM Studio: Any non-empty value (e.g., "lm-studio")
# - LocalAI: Usually not required, use "local"
OPENAI_API_KEY=your-api-key-here

# ===========================================
# LLM Settings (All Providers)
# ===========================================
# Base URL for the LLM service
# This is a convenience setting that maps to provider-specific URLs
LLM_BASE_URL=http://localhost:11434

# Model name
# - Ollama format: model:tag (e.g., qwen2.5:7b-instruct-q5_K_M)
# - OpenAI format: model-name (e.g., gpt-4-turbo, qwen3)
LLM_MODEL=qwen2.5:7b-instruct-q5_K_M

# API Key (for providers that require it)
LLM_API_KEY=not-required

# Temperature (0.0-1.0): Higher = more creative, Lower = more focused
LLM_TEMPERATURE=0.7

# Maximum tokens in response
LLM_MAX_TOKENS=4096

# Request timeout
LLM_TIMEOUT=60s

# Maximum retry attempts for failed requests
LLM_MAX_RETRIES=3

# ===========================================
# Speech-to-Text (Whisper)
# ===========================================
# Provider: openai-compatible (works with local Whisper server)
STT_PROVIDER=openai-compatible

# Local Whisper server URL (from local-deployment/)
STT_BASE_URL=http://localhost:9000

# Model name (for compatibility)
STT_MODEL=whisper-1

# API key (dummy for local service)
STT_API_KEY=local

# ===========================================
# Text-to-Speech (Piper/OpenAI TTS)
# ===========================================
# Provider: openai-compatible (works with local Piper server)
TTS_PROVIDER=openai-compatible

# Local Piper server URL (from local-deployment/)
TTS_BASE_URL=http://localhost:9001

# Model name (for compatibility)
TTS_MODEL=tts-1

# Voice selection
# OpenAI voices: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=alloy

# Speech speed (0.25-4.0)
TTS_SPEED=1.0

# API key (dummy for local service)
TTS_API_KEY=local

# ===========================================
# Image Generation (Stable Diffusion)
# ===========================================
# Provider: openai-compatible (works with local SD server)
IMAGE_PROVIDER=openai-compatible

# Local Stable Diffusion server URL
IMAGE_BASE_URL=http://localhost:7860

# Model name (for compatibility)
IMAGE_MODEL=dall-e-3

# Image size: 256x256, 512x512, 1024x1024
IMAGE_SIZE=512x512

# Quality: standard, hd
IMAGE_QUALITY=standard

# API key (dummy for local service)
IMAGE_API_KEY=local

# ===========================================
# Database Configuration
# ===========================================
# PostgreSQL connection string
#
# Deployment patterns:
# - Docker Compose: jdbc:postgresql://postgres:5432/language_learning
# - Local dev: jdbc:postgresql://localhost:5432/language_learning
# - Custom port: jdbc:postgresql://localhost:5433/language_learning
DATABASE_URL=jdbc:postgresql://localhost:5432/language_learning
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ===========================================
# Application Settings
# ===========================================
# Server port (default: 8080)
SERVER_PORT=8080

# Spring profile: dev, prod
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# Logging Configuration
# ===========================================
# Log levels: TRACE, DEBUG, INFO, WARN, ERROR
#
# LOG_LEVEL_ROOT: Root logger level (affects all loggers)
# LOG_LEVEL_APP: Application code (dev.languagelearning.*)
# LOG_LEVEL_HTTP: HTTP client logging (useful for API debugging)
# LOG_LEVEL_SPRING_AI: Spring AI framework logging
# LOG_LEVEL_SQL: SQL query logging (Hibernate)

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_HTTP=WARN
LOG_LEVEL_SPRING_AI=WARN
LOG_LEVEL_SQL=WARN

# ===========================================
# Storage Paths
# ===========================================
# Path for generated content (lessons, vocabulary, etc.)
CONTENT_PATH=./content

# Path for media files (audio, images)
MEDIA_PATH=./media

# ===========================================
# EXAMPLE CONFIGURATIONS
# ===========================================
#
# --- OLLAMA (Docker/Local) ---
# OLLAMA_CHAT_ENABLED=true
# OPENAI_CHAT_ENABLED=false
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen2.5:7b-instruct-q5_K_M
#
# --- LM STUDIO ---
# OLLAMA_CHAT_ENABLED=false
# OPENAI_CHAT_ENABLED=true
# LLM_BASE_URL=http://localhost:1234
# LLM_MODEL=qwen3
# OPENAI_API_KEY=lm-studio
# OPENAI_BASE_URL=http://localhost:1234
#
# --- OPENAI API ---
# OLLAMA_CHAT_ENABLED=false
# OPENAI_CHAT_ENABLED=true
# LLM_BASE_URL=https://api.openai.com
# LLM_MODEL=gpt-4-turbo
# OPENAI_API_KEY=sk-your-actual-key
# OPENAI_BASE_URL=https://api.openai.com