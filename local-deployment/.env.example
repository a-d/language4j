# Language Learning Platform - Local AI Configuration
# ==================================================
# Copy this file to the project root as .env for fully local AI deployment
# 
# This configuration uses:
# - Ollama for LLM (text generation)
# - Whisper for speech-to-text
# - Piper for text-to-speech (French)
# - Stable Diffusion for image generation
#
# Hardware requirements:
# - AMD GPU with ROCm support (tested on RX 7900 XTX)
# - 24GB+ VRAM recommended
# - 48GB+ system RAM recommended

# ===========================================
# Language Settings
# ===========================================
# Your native language (ISO 639-1 code)
NATIVE_LANGUAGE=de

# The language you want to learn (ISO 639-1 code)
TARGET_LANGUAGE=fr

# ===========================================
# LLM Configuration (Ollama)
# ===========================================
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
# Recommended models by Docker memory limit:
# - qwen2.5:7b-instruct-q5_K_M   (~10GB RAM - default Docker settings)
# - qwen2.5:14b-instruct-q5_K_M  (~21GB RAM - requires increased Docker memory)
# - qwen2.5:32b-instruct-q5_K_M  (~37GB RAM - requires max Docker memory)
# Note: Increase Docker Desktop memory (Settings > Resources) for larger models
LLM_MODEL=qwen2.5:7b-instruct-q5_K_M
# No API key needed for local Ollama
LLM_API_KEY=

# ===========================================
# Spring AI Provider Flags
# ===========================================
# Enable OpenAI-compatible audio services (required for TTS/STT)
OPENAI_SPEECH_ENABLED=true
OPENAI_TRANSCRIPTION_ENABLED=true
# Disable other OpenAI services (using Ollama for LLM)
OPENAI_CHAT_ENABLED=false
OPENAI_IMAGE_ENABLED=false
# Ollama for text generation
OLLAMA_CHAT_ENABLED=true

# ===========================================
# Speech-to-Text (Local Whisper)
# ===========================================
STT_PROVIDER=openai-compatible
STT_BASE_URL=http://localhost:9000
STT_MODEL=whisper-1
# Dummy API key for local service
STT_API_KEY=local

# ===========================================
# Text-to-Speech (Local Piper)
# ===========================================
TTS_PROVIDER=openai-compatible
TTS_BASE_URL=http://localhost:9001
TTS_MODEL=tts-1
TTS_VOICE=alloy
TTS_SPEED=1.0
# Dummy API key for local service
TTS_API_KEY=local

# ===========================================
# Image Generation (Local Stable Diffusion)
# ===========================================
IMAGE_PROVIDER=openai-compatible
IMAGE_BASE_URL=http://localhost:7860
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=512x512
IMAGE_QUALITY=standard
# Dummy API key for local service
IMAGE_API_KEY=local

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=jdbc:postgresql://localhost:5432/language_learning
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ===========================================
# Application Settings
# ===========================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# Storage Paths
# ===========================================
CONTENT_PATH=./content
MEDIA_PATH=./media