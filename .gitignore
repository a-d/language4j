# Build outputs
**/target/

# IDE
/.idea/
*.iml

# Environment files
# The active .env file (contains sensitive data, machine-specific config)
.env
.env.local

# Note: These environment TEMPLATES are intentionally tracked:
# - .env.example  : Documentation and all options
# - .env.ollama   : Ollama provider template
# - .env.lmstudio : LM Studio provider template

# Local deployment personal configuration
# Note: local-deployment/ contains personal local AI setup
# The .env.example template is tracked, but actual .env is not
local-deployment/.env
local-deployment/test-output/

# Content and media directories
/content/
/media/

# Logs
*.log
logs/
