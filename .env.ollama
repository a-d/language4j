# Language Learning Platform - Ollama Configuration
# ==================================================
# Profile: OLLAMA (Local Docker/WSL deployment)
#
# Usage: Copy this file to .env to use Ollama as the LLM provider
#        cp .env.ollama .env
#
# Requirements:
# - Ollama running in Docker (via docker-compose) or locally
# - Model pulled: ollama pull qwen2.5:7b-instruct-q5_K_M
#
# Docker Compose: docker-compose -f docker/docker-compose.yml up -d

# ===========================================
# Language Settings
# ===========================================
NATIVE_LANGUAGE=de
TARGET_LANGUAGE=fr

# ===========================================
# LLM Configuration (Ollama)
# ===========================================
LLM_PROVIDER=ollama

# Ollama URL (adjust based on deployment)
# - Local:  http://localhost:11434
# - Docker: http://ollama:11434 (from docker-compose network)
# - WSL:    http://host.docker.internal:11434
LLM_BASE_URL=http://localhost:11434

# Model name (Ollama format: name:tag)
LLM_MODEL=qwen2.5:7b-instruct-q5_K_M

# Not used for Ollama, but set for consistency
LLM_API_KEY=not-required

# ===========================================
# Spring AI Provider Flags
# ===========================================
# IMPORTANT: Enable ONLY ONE chat provider at a time!

# Enable Ollama for chat
OLLAMA_CHAT_ENABLED=true

# Disable OpenAI (LM Studio, LocalAI, OpenAI API)
OPENAI_CHAT_ENABLED=false
OPENAI_API_KEY=not-used
OPENAI_BASE_URL=https://api.openai.com

# Disable Anthropic
ANTHROPIC_CHAT_ENABLED=false

# Optional: OpenAI-compatible services (images, speech)
OPENAI_IMAGE_ENABLED=false
OPENAI_SPEECH_ENABLED=false
OPENAI_TRANSCRIPTION_ENABLED=false

# ===========================================
# Speech-to-Text (Local Whisper)
# ===========================================
STT_PROVIDER=openai-compatible
STT_BASE_URL=http://localhost:9000
STT_MODEL=whisper-1
STT_API_KEY=local

# ===========================================
# Text-to-Speech (Local Piper)
# ===========================================
TTS_PROVIDER=openai-compatible
TTS_BASE_URL=http://localhost:9001
TTS_MODEL=tts-1
TTS_VOICE=alloy
TTS_SPEED=1.0
TTS_API_KEY=local

# ===========================================
# Image Generation (Local Stable Diffusion)
# ===========================================
IMAGE_PROVIDER=openai-compatible
IMAGE_BASE_URL=http://localhost:7860
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=512x512
IMAGE_QUALITY=standard
IMAGE_API_KEY=local

# ===========================================
# Database Configuration
# ===========================================
# For Docker Compose: postgres:5432 (service name)
# For local dev: localhost:5432 or localhost:5433
DATABASE_URL=jdbc:postgresql://localhost:5433/language_learning
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ===========================================
# Application Settings
# ===========================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# Debug Logging
# ===========================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_HTTP=WARN
LOG_LEVEL_SPRING_AI=WARN

# ===========================================
# Storage Paths
# ===========================================
CONTENT_PATH=./content
MEDIA_PATH=./media