# Language Learning Platform - LM Studio Configuration
# ==================================================
# Profile: LM STUDIO (OpenAI-compatible local LLM server)
#
# Usage: Copy this file to .env to use LM Studio as the LLM provider
#        cp .env.lmstudio .env
#
# Requirements:
# - LM Studio running with a loaded model
# - Server enabled in LM Studio (Local Server tab)
# - Network accessible from the machine running the backend
#
# LM Studio Setup:
# 1. Download and install LM Studio from https://lmstudio.ai
# 2. Download a model (e.g., Qwen3, Llama, Mistral)
# 3. Load the model
# 4. Go to "Local Server" tab and start the server
# 5. Note the server address (default: http://localhost:1234)

# ===========================================
# Language Settings
# ===========================================
NATIVE_LANGUAGE=de
TARGET_LANGUAGE=fr

# ===========================================
# LLM Configuration (LM Studio - OpenAI Compatible)
# ===========================================
LLM_PROVIDER=openai

# LM Studio server URL
# - Local:  http://localhost:1234
# - Remote: http://192.168.x.x:1234 (your LM Studio machine IP)
LLM_BASE_URL=http://192.168.178.20:1234

# Model name as shown in LM Studio
# Check /v1/models endpoint for exact name
LLM_MODEL=qwen3

# LM Studio requires an API key but accepts any value
LLM_API_KEY=lm-studio

# ===========================================
# Spring AI Provider Flags
# ===========================================
# IMPORTANT: Enable ONLY ONE chat provider at a time!

# Disable Ollama
OLLAMA_CHAT_ENABLED=false

# Enable OpenAI provider (used for LM Studio, LocalAI, etc.)
OPENAI_CHAT_ENABLED=true

# OpenAI-compatible API settings (required for Spring AI)
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://192.168.178.20:1234

# Disable Anthropic
ANTHROPIC_CHAT_ENABLED=false

# Optional: OpenAI-compatible services (images, speech)
# Enable these if you have local services running
OPENAI_IMAGE_ENABLED=true
OPENAI_SPEECH_ENABLED=true
OPENAI_TRANSCRIPTION_ENABLED=true

# ===========================================
# Speech-to-Text (Local Whisper)
# ===========================================
STT_PROVIDER=openai-compatible
STT_BASE_URL=http://localhost:9000
STT_MODEL=whisper-1
STT_API_KEY=local

# ===========================================
# Text-to-Speech (Local Piper)
# ===========================================
TTS_PROVIDER=openai-compatible
TTS_BASE_URL=http://localhost:9001
TTS_MODEL=tts-1
TTS_VOICE=alloy
TTS_SPEED=1.0
TTS_API_KEY=local

# ===========================================
# Image Generation (Local Stable Diffusion)
# ===========================================
IMAGE_PROVIDER=openai-compatible
IMAGE_BASE_URL=http://localhost:7860
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=512x512
IMAGE_QUALITY=standard
IMAGE_API_KEY=local

# ===========================================
# Database Configuration
# ===========================================
# For Docker Compose: postgres:5432 (service name)
# For local dev: localhost:5432 or localhost:5433
DATABASE_URL=jdbc:postgresql://localhost:5433/language_learning
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ===========================================
# Application Settings
# ===========================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# Debug Logging
# ===========================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_HTTP=DEBUG
LOG_LEVEL_SPRING_AI=DEBUG

# ===========================================
# Storage Paths
# ===========================================
CONTENT_PATH=./content
MEDIA_PATH=./media